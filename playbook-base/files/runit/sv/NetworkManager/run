#!/bin/sh
exec 2>&1
# Absolute path: runsv run scripts boot with a near-empty env (stage 2 does
# `env - PATH=...`), so don't rely on $SVDIR. /service is the canonical dir.
# If dbus isn't up yet, exit 1 and let runsv retry — that's how runit
# expresses a dependency.
sv check /service/dbus >/dev/null 2>&1 || exit 1
# NM only has --debug for stderr logging (implies -n). With plain -n,
# logs go to syslog (sysklogd handles them → /var/log/messages). To
# pipe NM logs through runsv's log instead, configure
# /etc/NetworkManager/NetworkManager.conf [logging] section.
exec NetworkManager -n
