COMMON_FLAGS="{{ common_flags }}"
CFLAGS="${COMMON_FLAGS}"
CXXFLAGS="${COMMON_FLAGS}"
FCFLAGS="${COMMON_FLAGS}"
FFLAGS="${COMMON_FLAGS}"
RUSTFLAGS="-C target-cpu=native"

CHOST="x86_64-pc-linux-gnu"
MAKEOPTS="{{ makeopts_effective }}"

ACCEPT_KEYWORDS="{{ accept_keywords }}"
ACCEPT_LICENSE="{{ accept_license }}"

USE="{{ use_flags | join(' ') }}"

VIDEO_CARDS="{{ video_cards }}"
INPUT_DEVICES="libinput"

PORTAGE_TMPDIR="/var/tmp"
DISTDIR="/var/cache/distfiles"
PKGDIR="/var/cache/binpkgs"
# Drop the non-host CPU vendor's microcode (ships in linux-firmware) so dracut's
# early_microcode can't bundle dead weight into the UKI (Intel laptop => no AMD ucode).
# Also drop the host-loaded Intel ISH (Integrated Sensor Hub) firmware blobs: dracut
# has no per-firmware omit and the crypt module force-pulls intel-ishtp-hid, dragging
# ~8M of multi-vendor ish_*.bin into the UKI. Host-loaded ISH firmware is a Lunar
# Lake+ feature; pre-LNL machines never request it, so on this hardware it's pure dead
# weight (boot AND runtime). NOTE: a Lunar-Lake-or-newer *convertible* would lose its
# sensor-hub firmware here (auto-rotate/ALS) — drop this glob if you ever target one.
INSTALL_MASK="/boot/System.map* /boot/config* /lib/firmware/*/ish/*{% if cpu_microcode == 'intel' %} /lib/firmware/amd-ucode{% elif cpu_microcode == 'amd' %} /lib/firmware/intel-ucode{% endif %}"

FEATURES="${FEATURES} parallel-install ccache buildpkg"
CCACHE_DIR="/var/cache/ccache"
CCACHE_SIZE="15G"

EMERGE_DEFAULT_OPTS="--quiet-build=y --keep-going=y --jobs={{ emerge_jobs_effective }} --load-average={{ (ansible_facts['processor_vcpus'] | int) + 1 }}"

L10N="{{ default_locale.split('.')[0].split('_')[0] }}"
LINGUAS="{{ default_locale.split('.')[0].split('_')[0] }}"

GENTOO_MIRRORS="{{ gentoo_mirror | regex_replace('/releases/.*$', '') }}"
