#!/usr/sbin/nft -f
# Managed by playbook-desktop/tasks/08-firewall.yml -- do not edit by hand.
#
# Minimal host firewall: default-deny inbound, allow nothing outbound-restricted.
# `table inet` is a single table covering BOTH IPv4 and IPv6, so there is no v4/v6
# split to keep in sync. `nft -f` loads the whole ruleset atomically (all-or-
# nothing), so there is no half-applied state to get stuck in.
#
# The allowed ports come from config.yml (firewall_allowed_tcp_ports /
# firewall_allowed_udp_ports); add a port there and re-render to open it.

flush ruleset

table inet filter {
  chain input {
    # Drop anything not explicitly accepted below.
    type filter hook input priority 0; policy drop;

    ct state established,related accept   # replies to connections we started
    iif "lo" accept                       # loopback talks to itself
    ct state invalid drop                 # junk / out-of-state packets
    meta l4proto { icmp, icmpv6 } accept  # ping, IPv6 ND, path-MTU discovery
{% if firewall_allowed_tcp_ports | default([]) | length > 0 %}

    # inbound TCP whitelist (config.yml: firewall_allowed_tcp_ports)
    tcp dport { {{ firewall_allowed_tcp_ports | join(', ') }} } accept
{% endif %}
{% if firewall_allowed_udp_ports | default([]) | length > 0 %}

    # inbound UDP whitelist (config.yml: firewall_allowed_udp_ports)
    udp dport { {{ firewall_allowed_udp_ports | join(', ') }} } accept
{% endif %}
  }

  chain forward {
    # Not a router; forward nothing.
    type filter hook forward priority 0; policy drop;
  }

  chain output {
    # Trust this host's own outbound traffic.
    type filter hook output priority 0; policy accept;
  }
}
